# Admin password for the dashboard
ADMIN_PASSWORD=your-secure-password

# Vercel Postgres (auto-set by Vercel when you add Postgres storage)
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NO_SSL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# Google Forms - Published form ID (the one in the shareable link)
# e.g., from https://docs.google.com/forms/d/e/FORM_ID/viewform
GOOGLE_FORM_ID=

# Google Service Account JSON (for reading responses via API)
# Create at: console.cloud.google.com → APIs → Credentials → Service Account
# Enable: Google Forms API
# Share the Google Form with the service account email
GOOGLE_SERVICE_ACCOUNT_JSON=

# Public URL (for logout redirect)
NEXT_PUBLIC_URL=https://your-app.vercel.app
